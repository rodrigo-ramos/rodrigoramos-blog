---
// assets
import Github from "../../assets/icons/Github.astro";
import Mail from "../../assets/icons/Mail.astro";

const socials = [
  { link: "https://github.com/rodrigo-ramos", icon: Github, label: "GitHub" },
  { link: "mailto:root@rodrigoramos.me", icon: Mail, label: "root@rodrigoramos.me" },
];
---

<div class="flex flex-row gap-24">
  {
    socials.map((social) => {
      const Icon = social.icon;
      const isExternal = social.link.startsWith("http");
      return (
        <a
          href={social.link}
          class="text-base-100 hover:text-base-300"
          aria-label={social.label}
          title={social.label}
          target={isExternal ? "_blank" : undefined}
          rel={isExternal ? "noopener noreferrer" : undefined}
        >
          <Icon width={20} height={20} fill="currentColor" />
        </a>
      );
    })
  }
</div>
