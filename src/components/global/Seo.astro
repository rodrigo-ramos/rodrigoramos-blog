---
export interface Props {
  title: string;
  titleTemplate?: string;
  description: string;
  canonical?: string;
  keywords?: string;
  robots?: string;
  // Open Graph 
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: "website" | "article" | "product" | "profile" | string;
  siteName?: string;
  locale?: string;
  // Twitter / X 
  twitterCard?: "summary" | "summary_large_image" | "app" | "player";
  twitterSite?: string;
  twitterCreator?: string;
  // Article-specific 
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
  // Structured Data (JSON-LD) 
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  jsonLdEnabled?: boolean;
  // Misc
  lang?: string;
  next?: string;
  prev?: string;
  themeColor?: string;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title,
  titleTemplate,
  description,
  canonical,
  keywords,
  robots,
  ogImage,
  ogImageAlt,
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogType = "website",
  siteName,
  locale = "en_US",
  twitterCard = "summary_large_image",
  twitterSite,
  twitterCreator,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags = [],
  jsonLd,
  jsonLdEnabled = true,
  next,
  prev,
  themeColor,
  noindex = false,
  nofollow = false,
} = Astro.props;

// Derived values 

const formattedTitle = titleTemplate
  ? titleTemplate.replace("%s", title)
  : title;

const canonicalURL =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;

const robotsContent =
  robots ??
  [noindex ? "noindex" : "index", nofollow ? "nofollow" : "follow"].join(", ");

// Auto JSON-LD 

function buildJsonLd() {
  if (!jsonLdEnabled) return null;
  if (jsonLd) return jsonLd;

  const base: Record<string, unknown> = {
    "@context": "https://schema.org",
    "@type": ogType === "article" ? "Article" : "WebPage",
    name: formattedTitle,
    description,
    url: canonicalURL,
    ...(ogImage && { image: ogImage }),
    ...(siteName && {
      publisher: {
        "@type": "Organization",
        name: siteName,
        ...(ogImage && { logo: { "@type": "ImageObject", url: ogImage } }),
      },
    }),
  };

  if (ogType === "article") {
    if (articlePublishedTime) base.datePublished = articlePublishedTime;
    if (articleModifiedTime) base.dateModified = articleModifiedTime;
    if (articleAuthor)
      base.author = { "@type": "Person", name: articleAuthor };
    if (articleTags.length) base.keywords = articleTags.join(", ");
  }

  return base;
}

const structuredData = buildJsonLd();
---

<!-- Primary Meta Tags -->
<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={description} />
{keywords && <meta name="keywords" content={keywords} />}
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Pagination -->
{prev && <link rel="prev" href={prev} />}
{next && <link rel="next" href={next} />}

<!-- Theme colour -->
{themeColor && <meta name="theme-color" content={themeColor} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={locale} />
{siteName && <meta property="og:site_name" content={siteName} />}
{ogImage && (
  <>
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
  </>
)}

<!-- Article-specific OG -->
{ogType === "article" && (
  <>
    {articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}

<!-- Twitter / X Card -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
{twitterSite && <meta name="twitter:site" content={twitterSite} />}
{twitterCreator && <meta name="twitter:creator" content={twitterCreator} />}
{ogImage && (
  <>
    <meta name="twitter:image" content={ogImage} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
  </>
)}

<!-- JSON-LD Structured Data -->
{structuredData && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(structuredData, null, 2)}
  />
)}