---
// DISABLED — example section, not imported in /about.
// Kept as a reference template. Re-import in src/pages/about.astro to re-enable.

// components
import Section from "../../elements/Section.astro";
import ExperienceCard from "../../elements/ExperienceCard.astro";


// content collection
import { getCollection } from "astro:content";
const experience = await getCollection("experience");
---

<Section 
    aria-label="Experience"
    title="Experience"
    titleHeading="Dónde he trabajado"
>
    {
            experience.map((entry) => (
                <ExperienceCard 
                    title={entry.data.title}
                    timeline={entry.data.timeline}
                    description={entry.data.description}
                />
            ))
        }
</Section>